# RAG System configuration. Copy to .env and edit. All vars are prefixed RAG_.

# ---- Retrieval ----
RAG_RETRIEVAL_MODE=hybrid          # vector | pageindex | hybrid
RAG_TOP_K=6
RAG_HYBRID_STRATEGY=merge_rerank   # merge_rerank | pageindex_then_vector

# ---- LLM (OpenAI-compatible, per role) ----
# Default points at a local Ollama server (fully offline, no real key needed).
# Swap base_url/model to use OpenAI, OpenRouter, vLLM, LM Studio, Together, Groq, etc.
RAG_REASONING_BASE_URL=http://localhost:11434/v1
RAG_REASONING_API_KEY=ollama
RAG_REASONING_MODEL=qwen2.5:7b-instruct

RAG_GENERATION_BASE_URL=http://localhost:11434/v1
RAG_GENERATION_API_KEY=ollama
RAG_GENERATION_MODEL=qwen2.5:7b-instruct

# auto | json_schema | json_object | prompt
RAG_STRUCTURED_OUTPUT_MODE=auto

# ---- Embeddings (vector mode) ----
RAG_EMBEDDING_PROVIDER=local       # local | openai
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# For RAG_EMBEDDING_PROVIDER=openai, set an OpenAI-compatible /v1 endpoint:
# RAG_EMBEDDING_BASE_URL=http://localhost:11434/v1
# RAG_EMBEDDING_API_KEY=ollama

# ---- Chunking (vector) ----
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# ---- PageIndex ----
RAG_PAGEINDEX_MAX_PAGES_PER_NODE=10

# ---- Persistence ----
RAG_CHROMA_DIR=data/indexes/chroma
RAG_INDEX_DIR=data/indexes/pageindex
